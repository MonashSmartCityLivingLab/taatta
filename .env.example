# Example environment file.
# Copy this file as .env and fill in the appropriate values.
# WARNING: never push the .env file as it contains secrets!!!
ADMIN_POSTGRES_PASSWORD=changeme

# taatta credentials and hostnames
TAATTA_MOSQUITTO_HOST=mosquitto
TAATTA_MOSQUITTO_PORT=1883
TAATTA_POSTGRES_HOST=postgresql
TAATTA_POSTGRES_PORT=5432
TAATTA_POSTGRES_USER=taatta
TAATTA_POSTGRES_PASSWORD=changeme
TAATTA_REDIS_HOST=redis

# Chirpstack secret
# Fill in the value using this command: openssl rand -base64 32
CHIRPSTACK_SECRET=